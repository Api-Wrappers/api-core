{
	"compilerOptions": {
		// Environment setup & latest features
		"lib": ["ESNext"],
		"target": "ESNext",
		"module": "Preserve",
		"moduleDetection": "force",
		"jsx": "react-jsx",
		"allowJs": true,
		"types": ["bun"],

		// Bundler mode
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,

		// noEmit: tsc is used for type-checking only; tsdown drives the actual
		// build via its own rolldown pipeline. Declaration files are emitted by
		// tsdown's DTS plugin, not by tsc directly.
		"noEmit": true,

		// These two are read by tsdown's DTS plugin to know it should emit
		// declaration files and source maps for them.
		"declaration": true,
		"declarationMap": true,

		// Best practices
		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,

		// Some stricter flags (disabled by default)
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noPropertyAccessFromIndexSignature": false
	}
}
